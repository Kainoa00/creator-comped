# CreatorComped — Environment Variables
# Copy this file to .env.local and fill in your values

# ── Supabase ──────────────────────────────────────────────────
# Get these from: supabase.com > your project > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Mapbox ────────────────────────────────────────────────────
# Get from: account.mapbox.com > Tokens
NEXT_PUBLIC_MAPBOX_TOKEN=pk.eyJ1IjoieW91ci11c2VybmFtZSIsImEiOiJ...

# ── Sentry ────────────────────────────────────────────────────
# Get from: sentry.io > your project > Settings > Client Keys (DSN)
NEXT_PUBLIC_SENTRY_DSN=https://your-dsn@o0.ingest.sentry.io/0

# ── App ───────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
