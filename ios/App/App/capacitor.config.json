{
	"appId": "com.creatorcomped.app",
	"appName": "HIVE",
	"webDir": "out",
	"plugins": {
		"SplashScreen": {
			"launchShowDuration": 0,
			"backgroundColor": "#0a0a0a",
			"androidScaleType": "CENTER_CROP",
			"showSpinner": false
		},
		"StatusBar": {
			"style": "dark",
			"backgroundColor": "#0a0a0a"
		},
		"PushNotifications": {
			"presentationOptions": [
				"badge",
				"sound",
				"alert"
			]
		}
	},
	"ios": {
		"appendUserAgent": "HIVE"
	},
	"android": {
		"minSdkVersion": 24
	},
	"packageClassList": [
		"CAPCameraPlugin",
		"PushNotificationsPlugin",
		"SplashScreenPlugin",
		"StatusBarPlugin"
	]
}
